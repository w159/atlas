
# --- blumira ---
# Blumira MCP Server
# Generate a JWT token at: Blumira Portal > Settings > API Access
BLUMIRA_JWT_TOKEN=your-jwt-token

# --- threatlocker ---
# ThreatLocker MCP Server
# Generate API credentials in the ThreatLocker portal under your user profile / API keys.
THREATLOCKER_API_KEY=your-api-key

# Optional. The organization (tenant) UUID to scope requests to.
# Leave blank to operate against your primary organization.
# For MSPs working across child orgs, set this per-session or use threatlocker_organizations_list_children to pivot.
THREATLOCKER_ORGANIZATION_ID=

# --- knowbe4 ---
# KnowBe4 Security Awareness API Configuration
# Copy this file to .env and fill in your credentials

# API Key (required)
# Generated from KnowBe4 console: Account Settings > API > API Token
KNOWBE4_API_KEY=your-knowbe4-api-key

# Region (required)
# Your KnowBe4 data center region determines the API base URL
# Valid values: US, EU, CA, UK, DE
# US = us.api.knowbe4.com (default)
# EU = eu.api.knowbe4.com
# CA = ca.api.knowbe4.com
# UK = uk.api.knowbe4.com
# DE = de.api.knowbe4.com
KNOWBE4_REGION=US
