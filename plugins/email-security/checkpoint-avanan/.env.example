# Checkpoint Harmony Email & Collaboration (Avanan) API Configuration
# Copy this file to .env and fill in your credentials

# Client ID (required)
# Obtained from the Checkpoint Infinity Portal under API Keys
# Navigate to Settings > API Keys > Create New Key
CHECKPOINT_CLIENT_ID=your-client-id

# Client Secret (required)
# Generated alongside the Client ID in the Infinity Portal
# Store securely - this value cannot be retrieved after initial creation
CHECKPOINT_CLIENT_SECRET=your-client-secret

# MCP Server URL (optional)
# Override to use a self-hosted gateway instead of the default hosted MCP server
# Default: https://checkpoint-avanan-mcp.wyre.workers.dev/mcp
CHECKPOINT_AVANAN_MCP_URL=https://checkpoint-avanan-mcp.wyre.workers.dev/mcp
