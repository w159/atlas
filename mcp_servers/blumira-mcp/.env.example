# Blumira credentials — provide EITHER a JWT token OR OAuth client credentials.

# Option A: OAuth2 client credentials (recommended).
# Generated under Settings > Organization > Blumira API Credentials.
# The server exchanges these at https://auth.blumira.com/oauth/token
# (audience "public-api") for a bearer token automatically.
# BLUMIRA_CLIENT_ID=your-client-id
# BLUMIRA_CLIENT_SECRET=your-client-secret

# Option B: A pre-issued JWT bearer token (valid ~30 days, then refresh).
# BLUMIRA_JWT_TOKEN=your-jwt-token-here

# Optional. Leave blank to use the vendor default
# (https://api.blumira.com/public-api/v1). Only set for staging/sovereign shards.
# BLUMIRA_BASE_URL=

# Transport: stdio (default) or http
# MCP_TRANSPORT=http
# MCP_HTTP_PORT=8080
# MCP_HTTP_HOST=0.0.0.0

# Auth mode: env (default) or gateway
# AUTH_MODE=env

# Logging
# LOG_LEVEL=info
