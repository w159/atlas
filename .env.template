# =====================================================================
# MCP server credential template
#
# Copy to .env and fill in for the servers you want to test:
#     cp .env.template .env
#
# Then run end-to-end verification:
#     node test-mcp-tools.mjs           # exercise all servers
#     node test-mcp-tools.mjs auvik     # exercise one server
#
# Empty values are treated as "skip this server" by test-mcp-tools.mjs.
# =====================================================================

# ---------- Auvik (network monitoring) ----------
# Username + API key from Auvik portal. Region: us1 (default), eu1, anz1, etc.
AUVIK_USERNAME=
AUVIK_API_KEY=
AUVIK_REGION=us1

# ---------- Blumira (SIEM) ----------
# Long-lived JWT from Blumira portal -> Integrations -> API.
BLUMIRA_JWT_TOKEN=

# ---------- CIPP (M365 management) ----------
# Either CIPP_API_KEY (legacy static bearer) OR the OAuth trio
# (CIPP_TENANT_ID + CIPP_CLIENT_ID + CIPP_CLIENT_SECRET). Base URL is required.
CIPP_BASE_URL=
CIPP_API_KEY=
CIPP_TENANT_ID=
CIPP_CLIENT_ID=
CIPP_CLIENT_SECRET=

# ---------- ConnectWise Manage (PSA) ----------
CW_MANAGE_COMPANY_ID=
CW_MANAGE_PUBLIC_KEY=
CW_MANAGE_PRIVATE_KEY=
CW_MANAGE_CLIENT_ID=
# Base URL example: na.myconnectwise.net
CW_MANAGE_BASE_URL=na.myconnectwise.net

# ---------- KnowBe4 (security awareness) ----------
# API key from KnowBe4 -> Account Settings -> API.
# Region: us (default), eu, ca, uk, de
KNOWBE4_API_KEY=
KNOWBE4_REGION=us

# ---------- NinjaOne (RMM) ----------
# OAuth client credentials. Region: us (default), eu, ca, oc.
NINJAONE_CLIENT_ID=
NINJAONE_CLIENT_SECRET=
NINJAONE_REGION=us

# ---------- ThreatLocker (zero-trust EDR) ----------
# API key from Portal -> Administrators -> API Users.
# ORGANIZATION_ID is OPTIONAL (only required when acting on a child managed org).
# BASE_URL is OPTIONAL (only override if your tenant lives on a non-default shard;
# see https://threatlocker.kb.help/locating-your-organizations-instance/).
THREATLOCKER_API_KEY=
THREATLOCKER_ORGANIZATION_ID=
THREATLOCKER_BASE_URL=

# ---------- Vanta (GRC / compliance) ----------
# OAuth2 client_credentials from Vanta -> Settings -> API Tokens.
# CLIENT_ID + CLIENT_SECRET are required; BASE_URL is optional (defaults to
# https://api.vanta.com/v1 — only override if Vanta has moved you to a
# non-default shard). Tokens are minted on demand and cached for ~1 hour;
# the token endpoint is limited to 5 req/min so reuse is critical.
VANTA_CLIENT_ID=
VANTA_CLIENT_SECRET=
VANTA_BASE_URL=https://api.vanta.com/v1

# ---------- Paylocity (HR/payroll) ----------
# OAuth2 client_credentials from Paylocity developer portal.
# CLIENT_ID + CLIENT_SECRET are required. Token endpoint uses
# form-urlencoded body and tokens are cached for ~1 hour.
# COMPANY_ID is required to scope tool calls without passing companyId
# per call (every Paylocity API path embeds it).
# BASE_URL is optional (blank = https://api.paylocity.com).
# SANDBOX=true switches to https://apisandbox.paylocity.com (ignored if
# BASE_URL is set).
PAYLOCITY_CLIENT_ID=
PAYLOCITY_CLIENT_SECRET=
PAYLOCITY_COMPANY_ID=
PAYLOCITY_BASE_URL=
PAYLOCITY_SANDBOX=

# ---------- Kaseya Spanning Backup (SaaS backup for M365/GWS/Salesforce) ----------
# Admin email + API token from the Spanning admin console. Tokens are
# pair-bound to the admin email — any mismatch surfaces as a generic 401.
# Platform: m365 (default), gws (Google Workspace), salesforce.
# SPANNING_API_URL is only needed for staging shards.
SPANNING_ADMIN_EMAIL=
SPANNING_API_TOKEN=
SPANNING_PLATFORM=m365
SPANNING_API_URL=
