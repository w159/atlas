{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "rootDir": "../..",
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*",
    "../_shared/response-shaper.ts",
    "../_shared/error-envelope.ts",
    "../_shared/base-url.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
