{
  "name": "connectwise-manage-mcp",
  "version": "1.5.2",
  "description": "ConnectWise Manage (PSA) MCP server for Claude",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "connectwise-manage-mcp": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --dir src",
    "test:watch": "vitest --passWithNoTests --dir src",
    "pack:mcpb": "node scripts/pack-mcpb.js",
    "validate:mcpb": "mcpb validate manifest.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w159/tech-tools.git",
    "directory": "mcp_servers/connectwise-manage-mcp"
  },
  "keywords": [
    "mcp",
    "claude",
    "connectwise",
    "connectwise-manage",
    "psa",
    "msp"
  ],
  "author": "w159",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/w159/tech-tools/issues"
  },
  "homepage": "https://github.com/w159/tech-tools/tree/main/mcp_servers/connectwise-manage-mcp",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "overrides": {
    "esbuild": "^0.28.1",
    "minimatch": "^3.1.2"
  }
}
