
# --- blumira ---
# Blumira MCP Server
# Generate a JWT token at: Blumira Portal > Settings > API Access
BLUMIRA_JWT_TOKEN=your-jwt-token

# --- checkpoint-avanan ---
# Checkpoint Harmony Email & Collaboration (Avanan) API Configuration
# Copy this file to .env and fill in your credentials

# Client ID (required)
# Obtained from the Checkpoint Infinity Portal under API Keys
# Navigate to Settings > API Keys > Create New Key
CHECKPOINT_CLIENT_ID=your-client-id

# Client Secret (required)
# Generated alongside the Client ID in the Infinity Portal
# Store securely - this value cannot be retrieved after initial creation
CHECKPOINT_CLIENT_SECRET=your-client-secret

# MCP Server URL (optional)
# Override to use a self-hosted gateway instead of the default hosted MCP server
# Default: https://checkpoint-avanan-mcp.wyre.workers.dev/mcp
CHECKPOINT_AVANAN_MCP_URL=https://checkpoint-avanan-mcp.wyre.workers.dev/mcp

# --- proofpoint ---
# Proofpoint Email Protection API Configuration
# Copy this file to .env and fill in your credentials

# Service Principal (required)
# The service principal for your Proofpoint account
# Obtain from Proofpoint TAP Dashboard > Settings > Connected Applications
PROOFPOINT_SERVICE_PRINCIPAL=your-service-principal

# Service Secret (required)
# The API secret associated with your service principal
# Generated when you create a connected application in Proofpoint
PROOFPOINT_SERVICE_SECRET=your-service-secret

# MCP Server URL (required)
# The URL of the Proofpoint MCP server
# Override to use a self-hosted gateway
PROOFPOINT_MCP_URL=https://proofpoint-mcp.wyre.workers.dev/mcp

# --- threatlocker ---
# ThreatLocker MCP Server
# Generate API credentials in the ThreatLocker portal under your user profile / API keys.
THREATLOCKER_API_KEY=your-api-key

# Optional. The organization (tenant) UUID to scope requests to.
# Leave blank to operate against your primary organization.
# For MSPs working across child orgs, set this per-session or use threatlocker_organizations_list_children to pivot.
THREATLOCKER_ORGANIZATION_ID=

# --- knowbe4 ---
# KnowBe4 Security Awareness API Configuration
# Copy this file to .env and fill in your credentials

# API Key (required)
# Generated from KnowBe4 console: Account Settings > API > API Token
KNOWBE4_API_KEY=your-knowbe4-api-key

# Region (required)
# Your KnowBe4 data center region determines the API base URL
# Valid values: US, EU, CA, UK, DE
# US = us.api.knowbe4.com (default)
# EU = eu.api.knowbe4.com
# CA = ca.api.knowbe4.com
# UK = uk.api.knowbe4.com
# DE = de.api.knowbe4.com
KNOWBE4_REGION=US

# MCP Server URL (optional)
# Override to use a self-hosted gateway
# Default: https://knowbe4-mcp.wyre.workers.dev/mcp
KNOWBE4_MCP_URL=https://knowbe4-mcp.wyre.workers.dev/mcp
