# Sherweb Partner API Credentials
# Obtain from Sherweb Partner Portal: https://cumulus.sherweb.com
# Navigate to Security > APIs to generate credentials
#
# Client ID and Client Secret are used for OAuth 2.0 client credentials flow.
# The Subscription Key is your API Management subscription key (Ocp-Apim-Subscription-Key).
#
# See: https://developers.sherweb.com for full API documentation.

SHERWEB_CLIENT_ID=your-client-id-here
SHERWEB_CLIENT_SECRET=your-client-secret-here
SHERWEB_SUBSCRIPTION_KEY=your-subscription-key-here
SHERWEB_MCP_URL=https://your-sherweb-mcp-url-here
