{
  "name": "node-blumira",
  "version": "1.0.2",
  "description": "Typed Node.js client for the Blumira SIEM API; used by blumira-mcp.",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "blumira",
    "siem",
    "api",
    "msp",
    "security",
    "typescript"
  ],
  "author": "w159",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/w159/tech-tools.git",
    "directory": "mcp_node/node-blumira"
  },
  "bugs": {
    "url": "https://github.com/w159/tech-tools/issues"
  },
  "homepage": "https://github.com/w159/tech-tools/tree/main/mcp_node/node-blumira",
  "devDependencies": {
    "msw": "^2.4.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
