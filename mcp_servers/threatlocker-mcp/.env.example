# ThreatLocker API Configuration
THREATLOCKER_API_KEY=your_api_key_here
THREATLOCKER_ORGANIZATION_ID=your_org_id_here

# Transport Configuration
MCP_TRANSPORT=stdio
# MCP_TRANSPORT=http

# HTTP Transport Configuration (when MCP_TRANSPORT=http)
MCP_HTTP_PORT=8080
MCP_HTTP_HOST=0.0.0.0

# Authentication Mode
AUTH_MODE=env
# AUTH_MODE=gateway

# Logging
LOG_LEVEL=info