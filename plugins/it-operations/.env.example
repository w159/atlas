
# --- auvik ---
# Auvik API credentials (https://support.auvik.com/hc/en-us/sections/360002960071-Auvik-APIs)
AUVIK_USERNAME=your-email@company.com
AUVIK_API_KEY=your-api-key
# Region: one of us1 us2 us3 us4 eu1 eu2 au1 ca1 (omit to auto-detect)
AUVIK_REGION=us1

# --- ninjaone-rmm ---
# NinjaOne API Configuration
# Get credentials from Administration > Apps > API in your NinjaOne dashboard

# OAuth 2.0 Client Credentials
NINJAONE_CLIENT_ID=your_client_id
NINJAONE_CLIENT_SECRET=your_client_secret

# Region - one of: us, eu, oc
# us = app.ninjarmm.com
# eu = eu.ninjarmm.com
# oc = oc.ninjarmm.com
NINJAONE_REGION=us

# --- connectwise-psa ---
# ConnectWise PSA API Configuration
# Copy this file to .env and fill in your credentials

# Company ID (required)
# Your ConnectWise company identifier (codebase)
CW_COMPANY_ID=your-company-id

# API Public Key (required)
# Generated from System > Members > API Members
CW_PUBLIC_KEY=your-public-key

# API Private Key (required)
# Generated alongside the public key
CW_PRIVATE_KEY=your-private-key

# Client ID (required)
# Registered application client ID from developer.connectwise.com
CW_CLIENT_ID=your-client-id

# API URL (required)
# Regional API endpoint:
#   North America: api-na.myconnectwise.net
#   Europe: api-eu.myconnectwise.net
#   Australia: api-au.myconnectwise.net
CW_API_URL=api-na.myconnectwise.net
