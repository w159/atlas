# Proofpoint Email Protection API Configuration
# Copy this file to .env and fill in your credentials

# Service Principal (required)
# The service principal for your Proofpoint account
# Obtain from Proofpoint TAP Dashboard > Settings > Connected Applications
PROOFPOINT_SERVICE_PRINCIPAL=your-service-principal

# Service Secret (required)
# The API secret associated with your service principal
# Generated when you create a connected application in Proofpoint
PROOFPOINT_SERVICE_SECRET=your-service-secret

# MCP Server URL (required)
# The URL of the Proofpoint MCP server
# Override to use a self-hosted gateway
PROOFPOINT_MCP_URL=https://proofpoint-mcp.wyre.workers.dev/mcp
